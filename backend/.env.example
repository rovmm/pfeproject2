# ================================================================
#  SmartStudy Backend — Variables d'environnement requises
#
#  UTILISATION :
#    1. Copiez ce fichier :  cp .env.example .env
#    2. Remplissez chaque valeur dans .env
#    3. Ne commitez JAMAIS le fichier .env (il est dans .gitignore)
#
#  Les variables sans valeur par défaut sont OBLIGATOIRES.
#  L'application refusera de démarrer si elles sont absentes.
# ================================================================


# ── Base de données MySQL ─────────────────────────────────────
# URL complète de connexion JDBC.
# Pour Docker Compose, remplacez localhost par le nom du service.
# Exemple : jdbc:mysql://db:3306/Quiz
DB_URL=jdbc:mysql://localhost:3306/Quiz

# Identifiants MySQL
DB_USERNAME=root
DB_PASSWORD=your_database_password_here


# ── JWT ───────────────────────────────────────────────────────
# Clé secrète pour la signature HMAC-SHA256 des tokens.
# OBLIGATOIRE — doit faire au minimum 32 caractères (256 bits).
#
# Commande de génération (Linux / macOS / Git Bash) :
#   openssl rand -hex 32
#
# Exemple de valeur (NE PAS UTILISER en production) :
#   a3f8c1e2b4d67890abcdef1234567890a3f8c1e2b4d67890abcdef12345678
JWT_SECRET=replace-this-with-a-random-256-bit-hex-string


# ── AI (résumé PDF + analyse de code + génération de quiz) — Groq Cloud ─────
# Clé API Groq (https://console.groq.com). Compatible OpenAI.
# OBLIGATOIRE — sans ces valeurs, /api/pdf/summarize, /api/ai/** et la
# génération de quiz depuis un PDF échoueront.
GROK_API_URL=https://api.groq.com/openai/v1/chat/completions
GROK_API_KEY=gsk_your_groq_api_key_here
GROK_MODEL=llama-3.3-70b-versatile

# ── Vision IA (lecture d'images uniquement) — Mistral via Open WebUI ────────
# Endpoint OpenAI-compatible distinct, utilisé UNIQUEMENT pour les images
# uploadées dans le Drive (le modèle Groq ci-dessus ne lit pas les images).
VISION_API_URL=http://your-openwebui-host:8088/ollama/api/v1/chat/completions
VISION_API_KEY=sk-your_vision_api_key_here
VISION_MODEL=mistral


# ── Email (Gmail SMTP) ────────────────────────────────────────
# Nécessite un "mot de passe d'application" Gmail (pas votre mot de passe
# habituel) : myaccount.google.com/apppasswords
EMAIL_USERNAME=your_gmail@gmail.com
EMAIL_PASSWORD=your_16_char_gmail_app_password


# ── Frontend ──────────────────────────────────────────────────
# URL du frontend déployé (CORS, liens dans les emails).
FRONTEND_URL=http://localhost:5173


# ── Serveur ───────────────────────────────────────────────────
# Port HTTP de l'application Spring Boot (défaut : 8080).
SERVER_PORT=8080
