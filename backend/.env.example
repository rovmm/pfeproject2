# ================================================================
#  SmartStudy Backend — Variables d'environnement requises
#
#  UTILISATION :
#    1. Copiez ce fichier :  cp .env.example .env
#    2. Remplissez chaque valeur dans .env
#    3. Ne commitez JAMAIS le fichier .env (il est dans .gitignore)
#
#  Les variables sans valeur par défaut sont OBLIGATOIRES.
#  L'application refusera de démarrer si elles sont absentes.
# ================================================================


# ── Base de données MySQL ─────────────────────────────────────
# URL complète de connexion JDBC.
# Pour Docker Compose, remplacez localhost par le nom du service.
# Exemple : jdbc:mysql://db:3306/Quiz
DB_URL=jdbc:mysql://localhost:3306/Quiz

# Identifiants MySQL
DB_USERNAME=root
DB_PASSWORD=your_database_password_here


# ── JWT ───────────────────────────────────────────────────────
# Clé secrète pour la signature HMAC-SHA256 des tokens.
# OBLIGATOIRE — doit faire au minimum 32 caractères (256 bits).
#
# Commande de génération (Linux / macOS / Git Bash) :
#   openssl rand -hex 32
#
# Exemple de valeur (NE PAS UTILISER en production) :
#   a3f8c1e2b4d67890abcdef1234567890a3f8c1e2b4d67890abcdef12345678
JWT_SECRET=replace-this-with-a-random-256-bit-hex-string


# ── Groq AI — Résumé PDF + Analyse de code ───────────────────
# Clé API Groq (https://console.groq.com).
# OBLIGATOIRE — sans cette clé, /api/pdf/summarize et /api/ai/** échoueront.
GROQ_API_KEY=gsk_your_groq_api_key_here


# ── DeepSeek (désactivé — laisser vide si non utilisé) ───────
# La valeur vide est acceptée : l'application démarre normalement.
DEEPSEEK_API_KEY=


# ── Serveur ───────────────────────────────────────────────────
# Port HTTP de l'application Spring Boot (défaut : 8080).
SERVER_PORT=8080
